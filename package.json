{
  "name": "stringstack-digital-book-reader",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "sync-chapters": "node scripts/buildManifest.mjs",
    "new-book": "node scripts/create-book-branch.mjs",
    "list-books": "node -e \"console.log(JSON.parse(require('fs').readFileSync('books/registry.json','utf8')).books.map(b=>b.branch+' -> '+b.title).join('\\n'))\"",
    "dev": "npm run sync-chapters && vite",
    "build": "npm run sync-chapters && tsc && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-pageflip": "^2.0.3"
  }
}
